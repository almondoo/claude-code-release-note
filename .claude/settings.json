{
  "permissions": {
    "allow": [
      "Bash(pnpm dlx react-router typegen:*)",
      "Bash(pnpm dlx tsc:*)",
      "Bash(pnpm dlx react-router build:*)",
      "Bash(pnpm remove:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "Bash(pnpm add:*)",
      "Bash(pnpm run typecheck:*)",
      "Bash(pnpm run dev:*)",
      "WebSearch",
      "Bash(python3:*)",
      "Bash(ls:*)",
      "Bash(pnpm run build:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/kill-dev-server.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "plansDirectory": "./.claude/plans"
}
